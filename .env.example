TWELVE_DATA_API_KEY=
# Optional: enabled by default when TWELVE_DATA_API_KEY exists. Set false to use REST/cache only.
TWELVE_DATA_ENABLE_WEBSOCKET=true
TWELVE_DATA_WS_URL=wss://ws.twelvedata.com/v1/quotes/price
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional server-only fallback used when Supabase REST/Data API schema cache is broken.
# Get it from Supabase Dashboard > Project Settings > Database > Connection string.
# Use the pooled URI when possible. Keep this secret and never expose it in client code.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:YOUR_DATABASE_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

NEXT_PUBLIC_APP_URL=http://localhost:3101
